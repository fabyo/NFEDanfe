<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\NFEDanfe\NFEDanfe.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AnalysisLevel>latest</AnalysisLevel>
    <EnforceCodeStyleInBuild>true</EnforceCodeStyleInBuild>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>nfedanfe</ToolCommandName>
    <PackageId>NFEDanfe.Cli</PackageId>
    <Version>0.1.5</Version>
    <Authors>NFEDanfe Contributors</Authors>
    <Company>NFEDanfe</Company>
    <Description>Ferramenta de linha de comando para gerar DANFE em PDF a partir de XML NF-e autorizado.</Description>
    <PackageTags>danfe;nfe;nf-e;pdf;cli;dotnet-tool</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryType>git</RepositoryType>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>
